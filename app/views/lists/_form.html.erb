<%= form_with(model: @list) do |form| %>

  <!-- ERROS -->
  <% if @list.errors.any? %>
    <div style="color: red;">
      <h4>Erros:</h4>
      <ul>
        <% @list.errors.full_messages.each do |mensagem| %>
          <li><%= mensagem %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, "Título" %><br>
    <%= form.text_field :title, required: true, minlength: 3 %>
  </div>

  <div>
    <%= form.label :description, "Descrição" %><br>
    <%= form.text_area :description %>
  </div>

  <div>
    <%= form.submit %>
  </div>

<% end %>