<h1 class="text-2xl font-bold mb-4">Minhas Listas</h1>

<div id="board_lists"
     data-controller="sortable"
     data-sortable-group-value="lists"
     data-sortable-scroll-sensitivity="50"
     data-sortable-scroll-speed="15"
     class="flex gap-4 overflow-x-auto pb-4">

  <%= render @lists %>

  <!-- Box "Nova Lista" – NÃO arrastável -->
  <div id="new_list_form"
       data-sortable-ignore="true"
       class="min-w-[300px] bg-gray-100 p-4 rounded-lg shadow-md hover:shadow-lg transition duration-200">
    <h2 class="font-semibold mb-2">Nova Lista</h2>
    <%= render partial: "lists/form", locals: { list: List.new } %>
  </div>

</div>