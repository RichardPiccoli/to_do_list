<h1>Listas de Tarefas</h1>

<!-- Link para criar nova lista -->
<%= link_to "Nova Lista", new_list_path %>

<hr>

<!-- Verifica se existem listas -->
<% if @lists.any? %>

  <ul>
    <% @lists.each do |lista| %>
      <li>
        <!-- Nome da lista -->
        <strong><%= lista.title %></strong>

        <!-- Link para visualizar -->
        <%= link_to "Ver", list_path(lista) %>

        <!-- Link para editar -->
        <%= link_to "Editar", edit_list_path(lista) %>

        <!-- Link para deletar -->
        <%= link_to "Excluir", list_path(lista),
              data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" } %>
      </li>
    <% end %>
  </ul>

<% else %>
  <p>Nenhuma lista cadastrada.</p>
<% end %>