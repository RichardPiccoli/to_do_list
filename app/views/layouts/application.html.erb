<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "To Do List" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100 text-gray-900">

    <!-- HEADER -->
    <header class="flex items-center justify-between p-4 bg-white shadow">
      <div class="flex items-center gap-3">
        <img src="/images/logo.png" alt="Logo" class="h-14 w-16">
        <h1 class="text-xl font-bold">To Do List</h1>
      </div>

      <%# Links de autenticação: email + Sair (logado) ou Entrar + Cadastrar (deslogado) %>
      <nav class="flex items-center gap-4">
        <% if user_signed_in? %>
          <span class="text-sm text-gray-600"><%= current_user.email %></span>
          <%= link_to "Sair",
                destroy_user_session_path,
                data: { turbo_method: :delete },
                class: "text-purple-600 hover:text-purple-700 font-medium" %>
        <% else %>
          <%= link_to "Entrar",
                new_user_session_path,
                class: "text-purple-600 hover:text-purple-700 font-medium" %>
          <%= link_to "Cadastrar",
                new_user_registration_path,
                class: "text-purple-600 hover:text-purple-700 font-medium" %>
        <% end %>
      </nav>
    </header>

    <div id="flash_messages" class="p-4 min-h-[5.6rem]">
      <%= render "shared/flash" %>
    </div>

    <main class="px-4 pb-4 pt-0">
      <%= yield %>
    </main>

  </body>
</html>