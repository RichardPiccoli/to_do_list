<%# Página de login - formulário centralizado com Tailwind %>
<div class="flex flex-col items-center justify-center min-h-[60vh] py-8 px-4">
  <div class="w-full max-w-md p-6 bg-white rounded-lg shadow-md">
    <h2 class="text-xl font-bold mb-6 text-gray-900">Entrar</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
      <div>
        <%= f.label :email, class: "block text-sm font-medium mb-1 text-gray-700" %>
        <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              class: "w-full p-2 rounded border border-black" %>
      </div>

      <div>
        <%= f.label :password, "Senha", class: "block text-sm font-medium mb-1 text-gray-700" %>
        <%= f.password_field :password,
              autocomplete: "current-password",
              class: "w-full p-2 rounded border border-black" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me, class: "rounded border-gray-300" %>
          <%= f.label :remember_me, "Lembrar de mim", class: "text-sm text-gray-600" %>
        </div>
      <% end %>

      <div class="pt-2">
        <%= f.submit "Entrar",
              class: "w-full bg-purple-600 hover:bg-purple-700 text-white font-medium py-2 px-4 rounded cursor-pointer transition" %>
      </div>
    <% end %>

    <%# Links auxiliares: cadastro e recuperação de senha %>
    <div class="mt-6 pt-4 border-t border-gray-200 space-y-2 text-center text-sm">
      <%= link_to "Cadastrar-se",
            new_registration_path(resource_name),
            class: "block text-purple-600 hover:text-purple-700 font-medium" %>
      <% if devise_mapping.recoverable? %>
        <%= link_to "Esqueceu sua senha?",
              new_password_path(resource_name),
              class: "block text-purple-600 hover:text-purple-700 font-medium" %>
      <% end %>
    </div>
  </div>
</div>
