<%# Página de cadastro - formulário centralizado com Tailwind %>
<div class="flex flex-col items-center justify-center min-h-[60vh] py-8 px-4">
  <div class="w-full max-w-md p-6 bg-white rounded-lg shadow-md">
    <h2 class="text-xl font-bold mb-6 text-gray-900">Cadastrar-se</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "block text-sm font-medium mb-1 text-gray-700" %>
        <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              class: "w-full p-2 rounded border border-black" %>
      </div>

      <div>
        <%= f.label :password, "Senha", class: "block text-sm font-medium mb-1 text-gray-700" %>
        <%= f.password_field :password,
              autocomplete: "new-password",
              class: "w-full p-2 rounded border border-black mt-1" %>
        <%# Dicas sobre os requisitos de senha %>
        <p class="mt-1 text-xs text-gray-500">
          Mínimo 8 caracteres, pelo menos uma letra maiúscula e um caractere especial (! @ # $ % ^ & * etc.)
        </p>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirmar senha", class: "block text-sm font-medium mb-1 text-gray-700" %>
        <%= f.password_field :password_confirmation,
              autocomplete: "new-password",
              class: "w-full p-2 rounded border border-black" %>
      </div>

      <div class="pt-2">
        <%= f.submit "Cadastrar",
              class: "w-full bg-purple-600 hover:bg-purple-700 text-white font-medium py-2 px-4 rounded cursor-pointer transition" %>
      </div>
    <% end %>

    <%# Link para voltar ao login %>
    <div class="mt-6 pt-4 border-t border-gray-200 text-center">
      <%= link_to "Já tem conta? Entrar",
            new_session_path(resource_name),
            class: "text-purple-600 hover:text-purple-700 font-medium text-sm" %>
    </div>
  </div>
</div>
