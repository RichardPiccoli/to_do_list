<%# Usa lista passada como local ou @list do controller (ex.: partial no index) %>
<% lista = local_assigns[:list] || @list %>

<div class="w-full">
  <%= form_with(model: [lista, item], data: { turbo: true }, class: "w-full") do |form| %>

    <!-- ERROS - aparece acima do campo -->
    <% if item.errors.any? %>
      <div class="mb-2 p-2 rounded bg-red-100 text-red-800 border border-red-300 text-sm">
        <ul class="list-disc list-inside">
          <% item.errors.full_messages.each do |mensagem| %>
            <li><%= mensagem %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Container para campo + botão (inline) -->
    <div class="flex gap-2 w-full">
      <%= form.text_field :title,
            placeholder: "Nova tarefa...",
            class: "flex-1 px-2 py-1 rounded border border-gray-300" %>

      <%= form.submit "+",
            class: "bg-purple-600 text-white p-2 rounded hover:bg-purple-700 transition" %>
    </div>

  <% end %>
</div>