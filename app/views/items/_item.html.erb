<%# Partial responsável por renderizar um item de tarefa %>
<%# dom_id(item) gera um ID no formato "item_123" %>
<li id="<%= dom_id(item) %>"
    class="bg-white p-3 rounded shadow-md hover:shadow-lg transition flex justify-between items-center">

  <div class="flex items-center gap-2">

    <%# Formulário com checkbox para marcar como concluído %>
    <%= form_with(model: [list, item], method: :patch, data: { turbo: true }) do |form| %>
      <%= form.check_box :done,
            checked: item.done,
            onchange: "this.form.requestSubmit()" %>
    <% end %>

    <%# Título do item, com linha de texto riscado se concluído %>
    <span class="<%= 'line-through text-gray-400' if item.done %>">
      <%= item.title %>
    </span>

  </div>

  <%# Botão de exclusão do item %>
  <%= link_to "🗑",
        list_item_path(list, item),
        data: { turbo_method: :delete, turbo_confirm: "Excluir?" },
        class: "text-red-500 hover:scale-110 transition" %>

</li>